---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
import authorsData from '../data/authors.json';
import { generateFallbackAvatar } from '../utils/avatar';

type AuthorRecord = (typeof authorsData)[number] & {
	isTeam?: boolean;
	year?: number;
};

const teamAuthors = authorsData as AuthorRecord[];

const currentMembers = teamAuthors
	.filter((member) => member.isTeam !== false && !member.alumni)
	.sort((a, b) => (a.sortOrder ?? 99) - (b.sortOrder ?? 99));

const alumni = teamAuthors
	.filter((member) => member.isTeam !== false && member.alumni)
	.sort((a, b) => (a.sortOrder ?? 99) - (b.sortOrder ?? 99));

const collaborators = teamAuthors
	.filter((member) => member.isTeam === false)
	.sort((a, b) => (a.sortOrder ?? 99) - (b.sortOrder ?? 99));

const withFallback = (member: AuthorRecord) => ({
	...member,
	fallbackAvatar: generateFallbackAvatar(member.name),
});
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Team | ${SITE_TITLE}`} description="Research Team & Collaborators" />
		<style>
			.team-hero {
				text-align: center;
				margin-bottom: 3rem;
				padding: 2rem 0;
			}
			.team-hero h1 {
				font-family: var(--font-serif);
				font-size: 3.2rem;
				margin: 0 0 1rem 0;
				letter-spacing: -0.02em;
			}
			.team-hero p {
				font-size: 1.15rem;
				color: var(--color-text-muted);
				max-width: 700px;
				margin: 0 auto;
				line-height: 1.7;
			}

			/* Cards */
			.team-card {
				text-align: center;
				padding: 1.5rem;
				border: 1px solid var(--color-border);
				border-radius: 12px;
				background-color: var(--color-bg-offset);
				transition: all 0.2s ease;
				cursor: pointer;
			}
			.team-card:hover {
				transform: translateY(-4px);
				box-shadow: var(--shadow-md);
				border-color: var(--color-accent);
			}

			/* Avatar */
			.team-avatar {
				width: 140px;
				height: 140px;
				border-radius: 50%;
				object-fit: cover;
				object-position: center top;
				display: block;
				margin: 0 auto 0.75rem auto;
			}

			.team-name {
				font-weight: 700;
				font-size: 1.05rem;
				display: block;
				color: var(--color-text-main);
			}

			.team-role {
				font-size: 0.9rem;
				color: var(--color-accent);
			}

			.collab-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
				gap: 1.5rem;
				margin-top: 1.5rem;
			}
			.collab-card {
				display: flex;
				gap: 1rem;
				align-items: center;
				padding: 1.25rem;
				background-color: var(--color-bg-offset);
				border: 1px solid var(--color-border);
				border-radius: 12px;
				cursor: pointer;
				transition: all 0.2s ease;
			}
			.collab-card:hover {
				border-color: var(--color-accent);
				transform: translateY(-2px);
				box-shadow: var(--shadow-md);
			}
			.collab-card img {
				width: 48px;
				height: 48px;
				border-radius: 50%;
				object-fit: cover;
				flex-shrink: 0;
			}
			.collab-info .collab-name {
				font-weight: 700;
				font-size: 0.95rem;
				color: var(--color-text-main);
				display: block;
			}
			.collab-info .collab-affil {
				font-size: 0.8rem;
				color: var(--color-text-muted);
			}

			@media (max-width: 768px) {
				.team-hero h1 {
					font-size: 2.5rem;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<div class="team-hero">
				<h1>QuICC Team</h1>
				<p>
					We are a research group working on quantum information, computation and communication
					at ICC, Universidad de Buenos Aires.
				</p>
			</div>

			<h2>Current Members</h2>
			<div class="grid-3">
				{currentMembers.map((member) => {
					const profile = withFallback(member);
					return (
						<div
							class="team-card interactive-card author-modal-trigger"
							data-member={JSON.stringify(member)}
						>
							<img
								src={profile.avatar || profile.fallbackAvatar}
								alt={profile.name}
								class="team-avatar"
								onerror={`this.onerror=null;this.src='${profile.fallbackAvatar}'`}
							/>
							<span class="team-name">{profile.name}</span>
							<span class="team-role">{profile.title}</span>
						</div>
					);
				})}
			</div>

			{alumni.length > 0 && (
				<>
					<h2>Former Members</h2>
					<div class="grid-3">
						{alumni.map((member) => {
							const profile = withFallback(member);
							return (
								<div
									class="team-card interactive-card author-modal-trigger"
									data-member={JSON.stringify(member)}
								>
									<img
										src={profile.avatar || profile.fallbackAvatar}
										alt={profile.name}
										class="team-avatar"
										onerror={`this.onerror=null;this.src='${profile.fallbackAvatar}'`}
									/>
									<span class="team-name">{profile.name}</span>
									<span class="team-role">{profile.title}</span>
								</div>
							);
						})}
					</div>
				</>
			)}

			{collaborators.length > 0 && (
				<>
					<h2>Collaborators</h2>
					<div class="collab-grid">
						{collaborators.map((member) => {
							const profile = withFallback(member);
							return (
								<div class="collab-card author-modal-trigger" data-member={JSON.stringify(member)}>
									<img
										src={profile.avatar || profile.fallbackAvatar}
										alt={profile.name}
										onerror={`this.onerror=null;this.src='${profile.fallbackAvatar}'`}
									/>
									<div class="collab-info">
										<span class="collab-name">{profile.name}</span>
										<span class="collab-affil">{profile.title}</span>
									</div>
								</div>
							);
						})}
					</div>
				</>
			)}
		</main>

		<Footer />
	</body>
</html>