---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';

import publications from '../data/publications.json';

// ordenar por año (por si acaso)
publications.sort((a, b) => (b.year || 0) - (a.year || 0));

const grouped = Object.values(
  publications.reduce((acc, pub) => {
    if (!acc[pub.year]) acc[pub.year] = [];
    acc[pub.year].push(pub);
    return acc;
  }, {})
);

---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Publications | ${SITE_TITLE}`} description="Academic publications of the QuICC group" />
	</head>
	<body>
		<Header />

		<main>
			<h1>Publications</h1>

			<p>
				This list is automatically generated from ORCID records.
			</p>

			{Object.entries(
  publications.reduce((acc, pub) => {
    if (!acc[pub.year]) acc[pub.year] = [];
    acc[pub.year].push(pub);
    return acc;
  }, {})
)
.sort((a, b) => b[0] - a[0])
.map(([year, pubs]) => (
  <section class="year-group">
    <h2>{year}</h2>

    {pubs.map((pub) => (
      <article class="publication-item">
        <div class="pub-title">
          {pub.title}
        </div>

        <div class="pub-authors">
          {pub.authors?.join(", ") || pub.author}
        </div>

        <div class="pub-venue">
          {pub.venue}
        </div>

        <div class="pub-links">
          {pub.url && (
            <a href={pub.url} target="_blank">DOI</a>
          )}
        </div>
      </article>
    ))}
  </section>
))}
		</main>

		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 800px;
		margin: 0 auto;
		padding: 2rem 1rem;
	}

	h1 {
		margin-bottom: 1rem;
	}

	p {
		line-height: 1.6;
		color: var(--color-text-secondary);
	}

	.publication-list {
		margin-top: 2rem;
	}

	.publication-item {
		margin-bottom: 2rem;
		padding-bottom: 1.5rem;
		border-bottom: 1px solid var(--color-secondary);
	}

	.pub-title {
		font-weight: 600;
		margin-bottom: 0.4rem;
		font-size: 1.1rem;
	}

	.pub-authors {
		font-size: 0.95rem;
		color: var(--color-text-secondary);
		margin-bottom: 0.2rem;
	}

	.pub-meta {
		font-size: 0.9rem;
		color: var(--color-text-muted);
	}

    .year-group {
  margin-top: 2.5rem;
}

.year-group h2 {
  margin-bottom: 1rem;
}

.pub-links a {
  font-size: 0.9rem;
  color: var(--color-accent);
  text-decoration: none;
}

.pub-links a:hover {
  text-decoration: underline;
}
</style>