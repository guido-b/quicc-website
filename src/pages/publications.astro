---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';

import publications from '../data/publications.json';

// ordenar por año
publications.sort((a, b) => (b.year || 0) - (a.year || 0));

// agrupar por año
const grouped = Object.entries(
  publications.reduce((acc, pub) => {
    if (!acc[pub.year]) acc[pub.year] = [];
    acc[pub.year].push(pub);
    return acc;
  }, {})
).sort((a, b) => b[0] - a[0]);

function formatAuthors(authors) {
  if (!authors) return "";

  // limitar autores si hay muchos
  if (authors.length > 6) {
    return authors.slice(0, 6).join(", ") + ", et al.";
  }

  return authors.join(", ");
}
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={`Publications | ${SITE_TITLE}`}
      description="Academic publications of the QuICC group"
    />
  </head>

  <body>
    <Header />

    <main>
      <h1>Publications</h1>

      <p class="intro">
        This list is automatically generated from ORCID records.
      </p>

      {grouped.map(([year, pubs]) => (
        <section class="year-group">
          <h2>{year}</h2>

          {pubs.map((pub) => (
            <div class="publication-item">
              
              <span class="authors">
                {formatAuthors(pub.authors)}
              </span>

              <span class="title">
                {pub.title}
              </span>

              <span class="venue">
                <i>{pub.venue}</i> ({pub.year})
              </span>

              <span class="links">
                {pub.url && (
                  <a href={pub.url} target="_blank">DOI</a>
                )}
                {pub.arxiv && (
                  <a href={pub.arxiv} target="_blank">arXiv</a>
                )}
              </span>

            </div>
          ))}
        </section>
      ))}
    </main>

    <Footer />
  </body>
</html>

<style>
main {
  max-width: 800px;
  margin: 0 auto;
  padding: 2rem 1rem;
}

/* encabezado */
.intro {
  color: var(--color-text-muted);
  margin-bottom: 2rem;
}

/* año */
.year-group {
  margin-top: 2rem;
}

.year-group h2 {
  margin-bottom: 0.8rem;
  font-size: 1.4rem;
}

/* publicación */
.publication-item {
  margin-bottom: 0.9rem;
  line-height: 1.5;
  font-size: 0.95rem;
}

/* autores */
.authors {
  color: var(--color-text-muted);
}

/* título */
.title {
  display: block;
  font-weight: 500;
}

/* venue */
.venue {
  color: var(--color-text-secondary);
  margin-right: 0.5rem;
}

/* links */
.links a {
  margin-left: 0.5rem;
  font-size: 0.85rem;
  color: var(--color-accent);
  text-decoration: none;
}

.links a:hover {
  text-decoration: underline;
}
</style>