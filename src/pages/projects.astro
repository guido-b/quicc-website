---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';

import projects from '../data/projects.json';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Research | ${SITE_TITLE}`} description="Research and activities of the QuICC group" />
	</head>
	<body>
		<Header />

		<main>
			<h1>Research & Activities</h1>

			<p>
				We conduct research at the intersection of quantum physics and computer science, while
				actively contributing to education, collaboration, and technology transfer.
			</p>

			{projects.map((section) => (
				<section class="project-section">
					<h2>{section.title}</h2>

					<div class="project-list">
						{section.items.map((item) => (
							<div class="project-item">
								<h3>{item.title}</h3>
								<p>{item.description}</p>
							</div>
						))}
					</div>
				</section>
			))}
		</main>

		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 800px;
		margin: 0 auto;
		padding: 2rem 1rem;
	}

	h1 {
		margin-bottom: 1rem;
	}

	p {
		line-height: 1.35;
	}

	.project-section {
		margin-top: 3rem;
	}

	.project-section h2 {
		margin-bottom: 1.5rem;
	}

	.project-list {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1.2rem;
	}

	.project-item {
		padding: 1rem 1.1rem;
		border: 1px solid var(--color-border);
		border-radius: 12px;
		background-color: var(--color-bg-offset);
		transition: all 0.2s ease;
	}

	.project-item:hover {
		transform: translateY(-2px);
		box-shadow: var(--shadow-md);
		border-color: var(--color-accent);
	}

	.project-item p {
		margin-top: 0.25rem;
		margin-bottom: 0;
		color: var(--color-text-secondary);
		line-height: 1.35;
	}

	.project-item h3 {
		margin-bottom: 0.4rem;
		font-size: 1.2rem;
	}

	.project-item p {
		color: var(--color-text-secondary);
	}

	@media (max-width: 768px) {
		.project-list {
			grid-template-columns: 1fr;
		}
	}
</style>