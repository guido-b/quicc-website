---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';

import projects from '../data/projects.json';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Research | ${SITE_TITLE}`} description="Research and activities of the QuICC group" />
	</head>
	<body>
		<Header />

		<main>
			<h1>Research & Activities</h1>

			<p>
				The QuICC group (Quantum Information, Computation, and Communication) conducts
				research at the intersection of quantum physics and computer science, while
				actively contributing to education, collaboration, and technology transfer.
			</p>

			{projects.map((section) => (
				<section class="project-section">
					<h2>{section.title}</h2>

					<div class="project-list">
						{section.items.map((item) => (
							<div class="project-item">
								<h3>{item.title}</h3>
								<p>{item.description}</p>
							</div>
						))}
					</div>
				</section>
			))}
		</main>

		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 800px;
		margin: 0 auto;
		padding: 2rem 1rem;
	}

	h1 {
		margin-bottom: 1rem;
	}

	p {
		line-height: 1.6;
	}

	.project-section {
		margin-top: 3rem;
	}

	.project-section h2 {
		margin-bottom: 1.5rem;
	}

	.project-item {
		margin-bottom: 2rem;
		padding-bottom: 1.5rem;
		border-bottom: 1px solid var(--color-border);
	}

	.project-item h3 {
		margin-bottom: 0.4rem;
		font-size: 1.2rem;
	}

	.project-item p {
		color: var(--color-text-secondary);
	}
</style>