---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import AuthorLink from '../components/AuthorLink.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { url } from '../utils/paths';

type Props = CollectionEntry<'blog'>['data'] & { id?: string };

const { title, description, pubDate, updatedDate, heroImage, authors, id } = Astro.props;
const fallbackHero = id ? url(`/blog/${id}.png`) : url('/og.png');
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			html {
				scroll-padding-top: 5.5rem; /* Account for sticky header height when scrolling to anchors */
			}
			main {
				width: 100%;
				max-width: 100%;
				margin: 0;
			}
			.hero-image {
				width: 100%;
				overflow: hidden;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
				max-width: 100%;
				height: auto;
			}

			.blog-container {
				position: relative;
				max-width: 1200px;
				margin: 0 auto;
				display: flex;
				justify-content: center;
			}

			.prose-wrapper {
				position: relative;
				width: 760px;
				max-width: 100%;
			}

			.prose {
				width: 100%;
				padding: 1rem;
				color: rgb(var(--gray-dark));
			}
			.prose :global(p) {
				text-align: justify;
				hyphens: auto;
			}

			/* Style the remark-toc output */
			.prose :global(h2#table-of-contents) {
				display: none;
			}
			.prose :global(h2#table-of-contents + ul) {
				margin-bottom: 2rem;
				padding: 1rem;
				background: var(--color-bg-offset);
				border: 1px solid var(--color-border);
				border-radius: var(--radius);
				list-style: none;
			}
			.prose :global(h2#table-of-contents + ul li) {
				margin-bottom: 0.5rem;
			}
			.prose :global(h2#table-of-contents + ul a) {
				text-decoration: none;
				color: var(--color-text-muted);
			}
			.prose :global(h2#table-of-contents + ul a:hover) {
				color: var(--color-accent);
			}

			@media (min-width: 1200px) {
				.prose :global(h2#table-of-contents + ul) {
					position: absolute;
					top: 0;
					left: 100%;
					width: 250px;
					margin-left: 2rem;
					margin-bottom: 0;
				}
				/* This trick makes the absolutely positioned TOC behave "sticky" within the prose wrapper */
				.prose-wrapper {
					/* Need to remove position: relative if we want position: sticky to work based on the viewport?
					   Wait, position absolute cannot be sticky. Let's do this differently.
					   Since we want sticky, we should make it float or absolutely position it, but sticky needs to be in flow.
					   Let's absolute position a wrapper if we had one, but we don't.
					   Let's rethink: .prose > ul can just have `position: absolute; position: sticky;`? No.
					   If we set `.prose > ul` to `position: absolute` it leaves the flow, fixing the gap.
					   But it won't be sticky to the viewport.
					   To make it sticky without a gap, we can use float.
					   Actually, if we put position: absolute, it's relative to .prose-wrapper.
					   Then we can't do position: sticky easily.
					   What if we just use `float: right; margin-right: -280px; width: 250px; position: sticky; top: 5.5rem;`
					*/
				}
				.prose :global(h2#table-of-contents + ul) {
					position: sticky;
					float: right;
					clear: right;
					margin-right: -280px;
					top: 5.5rem; /* navbar height (4.5rem) + 1rem padding */
					max-height: calc(100vh - 6.5rem);
					overflow-y: auto;
				}
				.prose :global(h2#table-of-contents + ul)::before {
					content: "Table of Contents";
					display: block;
					font-weight: 700;
					margin-bottom: 0.5rem;
					color: var(--color-text-main);
					text-transform: uppercase;
					font-size: 0.8rem;
					letter-spacing: 0.05em;
				}
			}

			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
				font-size: 2.2rem;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
			}
			.last-updated-on {
				font-style: italic;
			}
			.blog-authors {
				display: flex;
				gap: 0.5rem;
				justify-content: center;
				flex-wrap: wrap;
				margin-top: 0.75rem;
				font-size: 0.9rem;
				color: var(--color-text-muted);
			}
			.blog-authors span {
				font-size: 0.9rem;
			}
			@media (max-width: 768px) {
				.title h1 {
					font-size: 1.6rem;
				}
				.prose {
					padding: 1rem 0.5rem;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage ? (
						<Image width={1020} height={510} src={heroImage} alt={title} />
					) : (
						<img width={1020} height={510} src={fallbackHero} alt={title} />
					)}
				</div>
				<div class="blog-container">
					<div class="prose-wrapper">
						<div class="prose">
							<div class="title">
							<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										Last updated on <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<h1>{title}</h1>
						{authors && authors.length > 0 && (
							<div class="blog-authors">
								{authors.map((authorId, i) => (
									<span>
										<AuthorLink nameOrSlug={authorId} />
										{i < authors.length - 1 ? ', ' : ''}
									</span>
								))}
							</div>
						)}
							<hr />
						</div>
						<slot />
						</div>
					</div>
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
